# ───────────────────────────────────────────────────────────────
# Live AirTrack configuration.
# Copy this file to ".env" and fill in any keys you have.
# Every external feed has a built-in simulation fallback, so the
# app runs fully even with NO keys set.
# ───────────────────────────────────────────────────────────────

# HTTP port the server listens on.
PORT=3000

# ── Flights (OpenSky Network) ──────────────────────────────────
# Anonymous access works without credentials (heavily rate-limited).
# Create a free account at https://opensky-network.org for higher limits.
# Leave blank to use anonymous access; if anonymous is rate-limited or
# unreachable, the app falls back to the flight simulator.
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# Force the flight simulator regardless of OpenSky availability.
# Useful for offline demos. Values: auto | real | sim
FLIGHTS_MODE=auto

# ── Ships (AISStream.io) ───────────────────────────────────────
# Free API key from https://aisstream.io . Without a key the ship
# simulator is used automatically.
AISSTREAM_API_KEY=

# Force ship data source: auto | real | sim
SHIPS_MODE=auto

# ── Weather (Open-Meteo) ───────────────────────────────────────
# Open-Meteo is free and needs no key. Set to "off" to disable
# weather-along-route lookups.
WEATHER=on

# Polling / refresh cadence (milliseconds).
FLIGHTS_REFRESH_MS=8000
SHIPS_REFRESH_MS=10000

# ── Simulation time-lapse ──────────────────────────────────────
# Simulated traffic advances this many times faster than real time so
# movement is clearly visible (real-world speeds barely move per second on
# a world map). Set to 1 for true real-time. Real feeds (OpenSky/AISStream)
# always move at true speed regardless of this value.
SIM_SPEED=60
